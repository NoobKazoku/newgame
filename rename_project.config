[template]
old_project_name=GFramework-Godot-Template
old_namespace=GFrameworkGodotTemplate
old_test_namespace=GFramework_Godot_Template.Tests

[scan]
exclude_dirs=.godot,.git,.idea,.vscode,.mono,.claude,bin,obj
content_patterns=*.cs,*.csproj,*.sln,*.DotSettings.user,project.godot,README.md,AGENTS.md,.gitignore,*.yml,*.yaml

[cleanup]
self_clean_files=rename_project.sh,rename_project.ps1,rename_project.config,.github/workflows/validate-rename-project.yml
