[gd_scene format=3]

[ext_resource type="Script" path="res://scripts/ui/component/OptionBrowser.cs" id="1_option_browser"]

[node name="OptionBrowser" type="PanelContainer"]
size_flags_horizontal = 3
size_flags_vertical = 3
script = ExtResource("1_option_browser")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 8
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 8
theme_override_constants/margin_bottom = 8

[node name="Root" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Toolbar" type="HBoxContainer" parent="Margin/Root"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="SearchInput" type="LineEdit" parent="Margin/Root/Toolbar"]
unique_name_in_owner = true
custom_minimum_size = Vector2(240, 0)
layout_mode = 2
size_flags_horizontal = 3
placeholder_text = "Search"

[node name="CategoryFilter" type="OptionButton" parent="Margin/Root/Toolbar"]
unique_name_in_owner = true
custom_minimum_size = Vector2(180, 0)
layout_mode = 2

[node name="Scroll" type="ScrollContainer" parent="Margin/Root"]
custom_minimum_size = Vector2(0, 240)
layout_mode = 2
size_flags_vertical = 3

[node name="EntryContainer" type="VBoxContainer" parent="Margin/Root/Scroll"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

[node name="EmptyStateLabel" type="Label" parent="Margin/Root"]
unique_name_in_owner = true
visible = false
layout_mode = 2
text = "No entries."
horizontal_alignment = 1

[node name="Footer" type="HBoxContainer" parent="Margin/Root"]
layout_mode = 2
theme_override_constants/separation = 8
alignment = 1

[node name="PreviousPageButton" type="Button" parent="Margin/Root/Footer"]
unique_name_in_owner = true
layout_mode = 2
text = "Prev"

[node name="PageLabel" type="Label" parent="Margin/Root/Footer"]
unique_name_in_owner = true
layout_mode = 2
text = "0/0"
horizontal_alignment = 1

[node name="NextPageButton" type="Button" parent="Margin/Root/Footer"]
unique_name_in_owner = true
layout_mode = 2
text = "Next"
