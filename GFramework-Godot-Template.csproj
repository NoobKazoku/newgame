    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <TargetFramework Condition=" '$(GodotTargetPlatform)' == 'android' ">net9.0</TargetFramework>
        <EnableDynamicLoading>true</EnableDynamicLoading>
        <RootNamespace>GFrameworkGodotTemplate</RootNamespace>
        <Nullable>enable</Nullable>
        <LangVersion>preview</LangVersion>
        <EnableGFrameworkGlobalUsings>true</EnableGFrameworkGlobalUsings>
        <UseLocalGFrameworkWorkspace Condition="'$(UseLocalGFrameworkWorkspace)' == '' and Exists('..\GFramework\GFramework.Game\GFramework.Game.csproj')">false</UseLocalGFrameworkWorkspace>
        <UseLocalGFrameworkWorkspace Condition="'$(UseLocalGFrameworkWorkspace)' == ''">false</UseLocalGFrameworkWorkspace>
