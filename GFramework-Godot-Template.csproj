            <LogicalName>%(Identity)</LogicalName>
        </EmbeddedResource>
        <EmbeddedResource Include="config\**\*.yml">
            <LogicalName>%(Identity)</LogicalName>
        </EmbeddedResource>
        <EmbeddedResource Include="schemas\**\*.json">
